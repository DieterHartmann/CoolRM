{
  "name": "@crm/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "generate": "prisma generate --schema=prisma/platform.prisma && prisma generate --schema=prisma/tenant.prisma",
    "migrate:dev": "prisma migrate dev --schema=prisma/platform.prisma",
    "migrate:deploy": "prisma migrate deploy --schema=prisma/platform.prisma",
    "migrate:status": "prisma migrate status --schema=prisma/platform.prisma",
    "studio": "prisma studio --schema=prisma/platform.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "typescript": "^5.7.3"
  }
}
