# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=crmplatform
POSTGRES_USER=crmapp
POSTGRES_PASSWORD=changeme_strong_password

# Connection URL used by Prisma and the API
DATABASE_URL=postgresql://crmapp:changeme_strong_password@localhost:5432/crmplatform

# The PostgreSQL role the API runs as (used for SET ROLE grant during provisioning)
APP_DB_USER=crmapp

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must be >=32 chars random string
JWT_SECRET=changeme_jwt_secret_at_least_32_chars_long

# AES-256-GCM key for encrypting OAuth tokens at rest
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=changeme_64_hex_chars_aes256_key_here_generate_with_openssl

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000

# ── Email (basic SMTP for Phase 1 notifications) ──────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=changeme_smtp_password
SMTP_FROM=noreply@example.com

# ── Stripe (scaffolded in Phase 1, activated in Phase 3) ─────────────────────
STRIPE_SECRET_KEY=sk_test_changeme
STRIPE_WEBHOOK_SECRET=whsec_changeme

# ── Platform ──────────────────────────────────────────────────────────────────
# Base URL of the deployed platform (used in widget embed codes)
PLATFORM_URL=https://yourdomain.com
