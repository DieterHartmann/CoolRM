{
  "name": "crm-platform",
  "private": true,
  "version": "0.0.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev:api": "pnpm --filter @crm/api dev",
    "dev:web": "pnpm --filter @crm/web dev",
    "build": "pnpm -r build",
    "db:generate": "pnpm --filter @crm/db generate",
    "db:migrate": "pnpm --filter @crm/db migrate:dev",
    "db:migrate:deploy": "pnpm --filter @crm/db migrate:deploy",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  }
}
